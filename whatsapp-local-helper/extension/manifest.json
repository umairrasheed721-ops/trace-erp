{
  "manifest_version": 3,
  "name": "Trace ERP WhatsApp Web Helper",
  "version": "1.0",
  "description": "Auto-pastes product images and templates in WhatsApp Web.",
  "permissions": [
    "activeTab",
    "clipboardWrite"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://*.shopify.com/*",
    "https://*.shopifycdn.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"]
    }
  ]
}
