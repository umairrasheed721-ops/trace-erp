        "custom_liquid_DWGqzJ": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<style>\n  .combo-bundle-wrapper {\n    border: 2px solid #000;\n    border-radius: 8px;\n    padding: 15px;\n    margin-top: 20px;\n    margin-bottom: 20px;\n    background-color: #fcfcfc;\n    font-family: inherit;\n  }\n  .combo-title {\n    font-size: 16px;\n    font-weight: bold;\n    margin-bottom: 15px;\n    text-align: center;\n  }\n  .bundle-row {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    margin-bottom: 12px;\n    padding-bottom: 12px;\n    border-bottom: 1px solid #eaeaea;\n  }\n  .bundle-row:last-of-type {\n    border-bottom: none;\n    margin-bottom: 5px;\n  }\n  .bundle-left {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n  }\n  .product-thumb {\n    width: 45px;\n    height: 45px;\n    object-fit: cover;\n    border-radius: 6px;\n    border: 1px solid #ddd;\n  }\n  .item-title {\n    font-weight: bold;\n    font-size: 13px;\n    display: block;\n    color: #333;\n  }\n  .item-price {\n    font-size: 12px;\n    color: #555;\n  }\n  .size-select {\n    padding: 6px 10px;\n    border-radius: 4px;\n    border: 1px solid #ccc;\n    font-size: 13px;\n    background-color: #fff;\n    cursor: pointer;\n  }\n  \n  /* NEW SUMMARY STYLES */\n  .order-summary-box {\n    background-color: #fff;\n    border: 1px dashed #ccc;\n    border-radius: 6px;\n    padding: 12px;\n    margin-bottom: 15px;\n  }\n  .summary-heading {\n    font-weight: bold;\n    font-size: 14px;\n    margin-bottom: 8px;\n    border-bottom: 1px solid #eee;\n    padding-bottom: 5px;\n  }\n  .summary-list {\n    list-style: none;\n    padding: 0;\n    margin: 0 0 10px 0;\n    font-size: 13px;\n    color: #444;\n  }\n  .summary-list li {\n    margin-bottom: 4px;\n  }\n  .summary-total {\n    display: flex;\n    justify-content: space-between;\n    font-weight: bold;\n    font-size: 16px;\n    color: #000;\n  }\n  .shipping-banner {\n    text-align: center;\n    padding: 8px;\n    border-radius: 4px;\n    font-size: 13px;\n    font-weight: bold;\n    margin-bottom: 15px;\n    transition: all 0.3s ease;\n  }\n\n  .combo-btn {\n    width: 100%;\n    background-color: #000;\n    color: #fff;\n    padding: 14px;\n    border: none;\n    border-radius: 4px;\n    font-size: 16px;\n    font-weight: bold;\n    cursor: pointer;\n    text-transform: uppercase;\n    transition: background-color 0.3s;\n  }\n  .combo-btn:hover {\n    background-color: #333;\n  }\n</style>\n\n<div class=\"combo-bundle-wrapper\">\n  <div class=\"combo-title\">🔥 Complete the Look with Adidas Trousers</div>\n  \n  <div class=\"bundle-row\">\n    <div class=\"bundle-left\">\n      <div style=\"width: 45px; text-align: center; font-size: 20px;\">✔️</div>\n      <div>\n        <span class=\"item-title\">2-Shirt Combo</span>\n        <span class=\"item-price\">This Item</span>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"bundle-row\">\n    <div class=\"bundle-left\">\n      <img class=\"product-thumb\" src=\"https://cdn.shopify.com/s/files/1/0678/5515/5459/files/tro_adi_black.jpg?v=1774648370\" alt=\"Black Trouser\">\n      <div>\n        <span class=\"item-title\">Black Trouser</span>\n        <span class=\"item-price\">Rs. 1599</span>\n      </div>\n    </div>\n    <select id=\"black-size\" class=\"size-select\" onchange=\"updateSummary()\">\n      <option value=\"none\">None</option>\n      <option value=\"44721314431235\">Medium</option>\n      <option value=\"44721314496771\">Large</option>\n      <option value=\"44721314562307\">XL</option>\n    </select>\n  </div>\n\n  <div class=\"bundle-row\">\n    <div class=\"bundle-left\">\n      <img class=\"product-thumb\" src=\"https://cdn.shopify.com/s/files/1/0678/5515/5459/files/tro_adi_navy.jpg?v=1774648350\" alt=\"Navy Trouser\">\n      <div>\n        <span class=\"item-title\">Navy Trouser</span>\n        <span class=\"item-price\">Rs. 1599</span>\n      </div>\n    </div>\n    <select id=\"navy-size\" class=\"size-select\" onchange=\"updateSummary()\">\n      <option value=\"none\">None</option>\n      <option value=\"44721314464003\">Medium</option>\n      <option value=\"44721314529539\">Large</option>\n      <option value=\"44721314595075\">XL</option>\n    </select>\n  </div>\n\n  <div class=\"bundle-row\">\n    <div class=\"bundle-left\">\n      <img class=\"product-thumb\" src=\"https://cdn.shopify.com/s/files/1/0678/5515/5459/files/tro_adi.jpg?v=1774648325\" alt=\"Grey Trouser\">\n      <div>\n        <span class=\"item-title\">Grey Trouser</span>\n        <span class=\"item-price\">Rs. 1599</span>\n      </div>\n    </div>\n    <select id=\"grey-size\" class=\"size-select\" onchange=\"updateSummary()\">\n      <option value=\"none\">None</option>\n      <option value=\"45965696041219\">Medium</option>\n      <option value=\"45965696073987\">Large</option>\n      <option value=\"45965696106755\">XL</option>\n    </select>\n  </div>\n\n  <div class=\"order-summary-box\">\n    <div class=\"summary-heading\">Your Custom Bundle:</div>\n    <ul id=\"live-item-list\" class=\"summary-list\">\n      <li id=\"main-combo-summary\">✔️ 1x 2-Shirt Combo</li>\n    </ul>\n    <div class=\"summary-total\">\n      <span>Order Total:</span>\n      <span id=\"live-total-price\">Rs. {{ product.price | divided_by: 100 }}</span>\n    </div>\n  </div>\n\n  <div id=\"shipping-banner\" class=\"shipping-banner\">\n    Calculating shipping...\n  </div>\n\n  <button class=\"combo-btn\" id=\"add-bundle-btn\" onclick=\"addBundleToCart()\">ADD TO CART</button>\n</div>\n\n<script>\n  // Dynamically map all available shirt sizes to their Shopify IDs\n  const comboVariantsMap = {\n    {% for variant in product.variants %}\n    \"{{ variant.id }}\": \"{{ variant.title | replace: '\"', '\\\"' }}\"{% if forloop.last == false %},{% endif %}\n    {% endfor %}\n  };\n\n  const basePrice = {{ product.price | divided_by: 100 }};\n  const trouserPrice = 1599;\n  const freeShippingThreshold = 4999;\n\n  // Run the math as soon as the page loads\n  document.addEventListener(\"DOMContentLoaded\", updateSummary);\n\n  // Watch the page for any clicks or changes (like the customer selecting a new shirt size)\n  document.addEventListener('change', function() {\n    setTimeout(updateSummary, 100); \n  });\n\n  function updateSummary() {\n    let currentTotal = basePrice;\n    \n    // Check the URL for the currently selected Shirt size, fallback to default if none\n    const urlParams = new URLSearchParams(window.location.search);\n    let mainProductId = urlParams.get('variant') || \"{{ product.selected_or_first_available_variant.id }}\";\n    let comboSizeText = comboVariantsMap[mainProductId] || \"{{ product.selected_or_first_available_variant.title }}\";\n\n    // Build the dynamic receipt list starting with the exact shirt size\n    let listHtml = '<li>✔️ 1x 2-Shirt Combo (' + comboSizeText + ')</li>';\n\n    const blackDropdown = document.getElementById('black-size');\n    const navyDropdown = document.getElementById('navy-size');\n    const greyDropdown = document.getElementById('grey-size');\n\n    // Add Black Trouser\n    if (blackDropdown.value !== \"none\") {\n      currentTotal += trouserPrice;\n      const sizeText = blackDropdown.options[blackDropdown.selectedIndex].text;\n      listHtml += '<li>➕ 1x Black Trouser (' + sizeText + ')</li>';\n    }\n    \n    // Add Navy Trouser\n    if (navyDropdown.value !== \"none\") {\n      currentTotal += trouserPrice;\n      const sizeText = navyDropdown.options[navyDropdown.selectedIndex].text;\n      listHtml += '<li>➕ 1x Navy Trouser (' + sizeText + ')</li>';\n    }\n    \n    // Add Grey Trouser\n    if (greyDropdown.value !== \"none\") {\n      currentTotal += trouserPrice;\n      const sizeText = greyDropdown.options[greyDropdown.selectedIndex].text;\n      listHtml += '<li>➕ 1x Grey Trouser (' + sizeText + ')</li>';\n    }\n\n    // Output to the screen\n    document.getElementById('live-item-list').innerHTML = listHtml;\n    document.getElementById('live-total-price').innerText = 'Rs. ' + currentTotal.toLocaleString();\n\n    // Update the Free Shipping Banner\n    const banner = document.getElementById('shipping-banner');\n    if (currentTotal >= freeShippingThreshold) {\n      banner.innerHTML = '🎉 You have unlocked <b>FREE SHIPPING!</b>';\n      banner.style.backgroundColor = '#e6ffe6'; \n      banner.style.color = '#008000'; \n      banner.style.border = '1px solid #008000';\n    } else {\n      let difference = freeShippingThreshold - currentTotal;\n      banner.innerHTML = '🚚 Add <b>Rs. ' + difference.toLocaleString() + '</b> more to unlock Free Shipping!';\n      banner.style.backgroundColor = '#ffe6e6'; \n      banner.style.color = '#d90000'; \n      banner.style.border = '1px solid #d90000';\n    }\n  }\n\n  function addBundleToCart() {\n    const btn = document.getElementById('add-bundle-btn');\n    \n    const blackTrouser = document.getElementById('black-size').value;\n    const navyTrouser = document.getElementById('navy-size').value;\n    const greyTrouser = document.getElementById('grey-size').value;\n\n    btn.innerText = \"Adding to cart...\";\n    btn.style.backgroundColor = \"#555\";\n\n    const urlParams = new URLSearchParams(window.location.search);\n    let mainProductId = urlParams.get('variant') || \"{{ product.selected_or_first_available_variant.id }}\";\n\n    let cartItems = [\n      { 'id': mainProductId, 'quantity': 1 }\n    ];\n\n    if (blackTrouser !== \"none\") cartItems.push({ 'id': parseInt(blackTrouser), 'quantity': 1 });\n    if (navyTrouser !== \"none\") cartItems.push({ 'id': parseInt(navyTrouser), 'quantity': 1 });\n    if (greyTrouser !== \"none\") cartItems.push({ 'id': parseInt(greyTrouser), 'quantity': 1 });\n\n    fetch(window.Shopify.routes.root + 'cart/add.js', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ 'items': cartItems })\n    })\n    .then(response => {\n      if(response.ok) {\n        window.location.href = \"/checkout\"; \n      } else {\n        alert(\"Something went wrong. Please try again.\");\n        btn.innerText = \"ADD TO CART\";\n        btn.style.backgroundColor = \"#000\";\n      }\n    })\n    .catch((error) => {\n      console.error('Error:', error);\n      btn.innerText = \"ADD TO CART\";\n      btn.style.backgroundColor = \"#000\";\n    });\n  }\n</script>"
          }
        },
