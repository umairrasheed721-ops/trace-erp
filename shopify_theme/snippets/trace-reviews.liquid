{%- comment -%}
  trace-reviews.liquid
  
  Custom TRACE review widget.
  Fetches reviews from our backend API — no Judge.me dependency.

  Usage in product template:
    {% render 'trace-reviews',
       product: product,
       linked_handles: 'texture-white,texture-black,texture-navy',
       combined: true
    %}
  
  If combined is false (default), only this product's reviews are shown.
{%- endcomment -%}

{%- assign _backend_url = 'https://trace-erp-production.up.railway.app' -%}
{%- assign _this_handle = product.handle -%}

{%- comment -%} Build handles list for API call {%- endcomment -%}
{%- if combined and linked_handles != blank -%}
  {%- assign _all_handles = linked_handles -%}
  {%- unless _all_handles contains _this_handle -%}
    {%- assign _all_handles = _this_handle | append: ',' | append: _all_handles -%}
  {%- endunless -%}
{%- else -%}
  {%- assign _all_handles = _this_handle -%}
{%- endif -%}

<section class="trace-reviews-section" id="trace-reviews-{{ product.id }}" aria-label="Customer Reviews">
  <div class="trace-reviews-wrap">

    <!-- Header -->
    <div class="tr-header">
      <h2 class="tr-title">Customer Reviews</h2>
      <div class="tr-summary-row" id="tr-summary-{{ product.id }}">
        <div class="tr-skeleton-line" style="width:180px;height:40px;"></div>
      </div>
    </div>

    <!-- Rating Bars -->
    <div class="tr-rating-breakdown" id="tr-breakdown-{{ product.id }}" style="display:none;">
      {% for i in (1..5) %}
        {%- assign star = 6 | minus: i -%}
        <div class="tr-bar-row">
          <span class="tr-bar-label">{{ star }}★</span>
          <div class="tr-bar-track">
            <div class="tr-bar-fill" data-star="{{ star }}" style="width:0%"></div>
          </div>
          <span class="tr-bar-count" data-star-count="{{ star }}">0</span>
        </div>
      {% endfor %}
    </div>

    <!-- Reviews List -->
    <div class="tr-reviews-list" id="tr-list-{{ product.id }}">
      <div class="tr-loading">
        <div class="tr-spinner"></div>
        <span>Loading reviews...</span>
      </div>
    </div>

    <!-- Load More -->
    <div class="tr-load-more-wrap" id="tr-loadmore-wrap-{{ product.id }}" style="display:none;">
      <button class="tr-load-more-btn" id="tr-loadmore-{{ product.id }}">Load More Reviews</button>
    </div>

    <!-- Empty State -->
    <div class="tr-empty" id="tr-empty-{{ product.id }}" style="display:none;">
      <div class="tr-empty-icon">✍️</div>
      <p>No reviews yet. Be the first to review this product!</p>
    </div>

  </div>
</section>

<style>
/* ── TRACE Reviews Widget ─────────────────────────────────────── */
.trace-reviews-section {
  padding: 60px 0 40px;
  border-top: 1px solid rgba(255,255,255,0.08);
  margin-top: 60px;
}

.trace-reviews-wrap {
  max-width: 820px;
  margin: 0 auto;
  padding: 0 20px;
}

/* Header */
.tr-header { margin-bottom: 32px; }
.tr-title {
  font-size: 22px;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin: 0 0 20px;
  color: inherit;
}

/* Summary row */
.tr-summary-row {
  display: flex;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
}

.tr-avg-score {
  font-size: 52px;
  font-weight: 900;
  line-height: 1;
  color: inherit;
}

.tr-avg-right { display: flex; flex-direction: column; gap: 4px; }

.tr-stars-row { display: flex; gap: 3px; }
.tr-star-filled { color: #FFD700; font-size: 20px; }
.tr-star-half { color: #FFD700; font-size: 20px; opacity: 0.5; }
.tr-star-empty { color: #444; font-size: 20px; }

.tr-total-count {
  font-size: 13px;
  color: #888;
  letter-spacing: 1px;
}

/* Rating Bars */
.tr-rating-breakdown {
  margin-bottom: 36px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.tr-bar-row { display: flex; align-items: center; gap: 12px; }
.tr-bar-label { font-size: 13px; color: #888; width: 24px; text-align: right; flex-shrink: 0; }
.tr-bar-track {
  flex: 1;
  height: 6px;
  background: rgba(255,255,255,0.08);
  border-radius: 99px;
  overflow: hidden;
}
.tr-bar-fill {
  height: 100%;
  background: #FFD700;
  border-radius: 99px;
  transition: width 0.8s cubic-bezier(0.4,0,0.2,1);
}
.tr-bar-count { font-size: 12px; color: #666; width: 20px; flex-shrink: 0; }

/* Review Cards */
.tr-reviews-list { display: flex; flex-direction: column; gap: 20px; }

.tr-review-card {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 14px;
  padding: 24px;
  transition: border-color 0.2s;
  animation: trFadeIn 0.4s ease both;
}
.tr-review-card:hover { border-color: rgba(255,255,255,0.14); }

@keyframes trFadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

.tr-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 12px;
  flex-wrap: wrap;
}

.tr-card-left { display: flex; flex-direction: column; gap: 4px; }

.tr-reviewer-name {
  font-size: 14px;
  font-weight: 700;
  color: inherit;
  display: flex;
  align-items: center;
  gap: 8px;
}

.tr-verified-badge {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 1px;
  background: rgba(74,222,128,0.15);
  color: #4ade80;
  border: 1px solid rgba(74,222,128,0.25);
  border-radius: 99px;
  padding: 2px 8px;
  text-transform: uppercase;
}

.tr-card-stars { display: flex; gap: 2px; }
.tr-card-star-filled { color: #FFD700; font-size: 14px; }
.tr-card-star-empty  { color: #333; font-size: 14px; }

.tr-card-meta {
  font-size: 12px;
  color: #555;
  display: flex;
  gap: 8px;
  align-items: center;
}
.tr-meta-sep { color: #333; }

.tr-card-title {
  font-size: 15px;
  font-weight: 700;
  color: inherit;
  margin: 0 0 8px;
}

.tr-card-body {
  font-size: 14px;
  line-height: 1.65;
  color: #aaa;
  margin: 0;
  white-space: pre-wrap;
  word-break: break-word;
}

/* Loading */
.tr-loading {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 32px 0;
  color: #666;
  font-size: 14px;
}

.tr-spinner {
  width: 20px; height: 20px;
  border: 2px solid rgba(255,255,255,0.1);
  border-top-color: #888;
  border-radius: 50%;
  animation: trSpin 0.8s linear infinite;
  flex-shrink: 0;
}
@keyframes trSpin { to { transform: rotate(360deg); } }

/* Skeleton */
.tr-skeleton-line {
  background: linear-gradient(90deg, rgba(255,255,255,0.04) 25%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0.04) 75%);
  background-size: 200% 100%;
  animation: trShimmer 1.5s infinite;
  border-radius: 8px;
}
@keyframes trShimmer { to { background-position: -200% 0; } }

/* Load more */
.tr-load-more-wrap { text-align: center; margin-top: 28px; }
.tr-load-more-btn {
  background: transparent;
  border: 1px solid rgba(255,255,255,0.15);
  color: #aaa;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 13px 32px;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.2s;
}
.tr-load-more-btn:hover {
  border-color: rgba(255,255,255,0.3);
  color: #fff;
}

/* Empty */
.tr-empty {
  text-align: center;
  padding: 48px 0;
  color: #555;
}
.tr-empty-icon { font-size: 36px; margin-bottom: 12px; }
.tr-empty p { font-size: 14px; }

/* Responsive */
@media (max-width: 640px) {
  .tr-avg-score { font-size: 40px; }
  .tr-review-card { padding: 18px; }
}
</style>

<script>
(function() {
  var BACKEND = '{{ _backend_url }}';
  var HANDLES = '{{ _all_handles | escape }}';
  var PRODUCT_ID = '{{ product.id }}';
  var PAGE = 1;
  var LIMIT = 10;
  var totalLoaded = 0;
  var totalAvailable = 0;

  function makeStars(rating, size) {
    size = size || 'card';
    var html = '';
    for (var i = 1; i <= 5; i++) {
      if (i <= rating) {
        html += '<span class="tr-' + size + '-star-filled">★</span>';
      } else {
        html += '<span class="tr-' + size + '-star-empty">★</span>';
      }
    }
    return html;
  }

  function makeSummaryStars(avg) {
    var html = '';
    for (var i = 1; i <= 5; i++) {
      if (avg >= i) {
        html += '<span class="tr-star-filled">★</span>';
      } else if (avg >= i - 0.5) {
        html += '<span class="tr-star-half">★</span>';
      } else {
        html += '<span class="tr-star-empty">★</span>';
      }
    }
    return html;
  }

  function formatDate(dateStr) {
    if (!dateStr) return '';
    try {
      var d = new Date(dateStr);
      return d.toLocaleDateString('en-PK', { year: 'numeric', month: 'short', day: 'numeric' });
    } catch(e) { return ''; }
  }

  function renderSummary(summary) {
    var summaryEl = document.getElementById('tr-summary-' + PRODUCT_ID);
    if (!summaryEl) return;

    if (!summary || summary.total === 0) {
      summaryEl.innerHTML = '<span style="color:#666;font-size:14px;">No reviews yet</span>';
      return;
    }

    summaryEl.innerHTML =
      '<div class="tr-avg-score">' + (summary.avg || 0).toFixed(1) + '</div>' +
      '<div class="tr-avg-right">' +
        '<div class="tr-stars-row">' + makeSummaryStars(summary.avg || 0) + '</div>' +
        '<div class="tr-total-count">' + summary.total + ' review' + (summary.total !== 1 ? 's' : '') + '</div>' +
      '</div>';
  }

  function renderBreakdown(summary) {
    var el = document.getElementById('tr-breakdown-' + PRODUCT_ID);
    if (!el || !summary || summary.total === 0) return;

    el.style.display = 'flex';
    for (var s = 1; s <= 5; s++) {
      var fill = el.querySelector('[data-star="' + s + '"]');
      var count = el.querySelector('[data-star-count="' + s + '"]');
      var n = (summary.distribution && summary.distribution[s]) || 0;
      var pct = summary.total > 0 ? Math.round((n / summary.total) * 100) : 0;
      if (fill) {
        setTimeout((function(f, p) { return function() { f.style.width = p + '%'; }; })(fill, pct), 100);
      }
      if (count) count.textContent = n;
    }
  }

  function renderReviews(reviews, append) {
    var listEl = document.getElementById('tr-list-' + PRODUCT_ID);
    if (!listEl) return;

    if (!append) listEl.innerHTML = '';

    reviews.forEach(function(r, idx) {
      var card = document.createElement('div');
      card.className = 'tr-review-card';
      card.style.animationDelay = (idx * 0.05) + 's';

      var nameInitial = (r.name || 'A').charAt(0).toUpperCase();
      var dateStr = formatDate(r.date);
      var location = r.location ? ('<span class="tr-meta-sep">·</span><span>' + r.location + '</span>') : '';
      var titleHtml = r.title ? '<p class="tr-card-title">' + escHtml(r.title) + '</p>' : '';

      card.innerHTML =
        '<div class="tr-card-top">' +
          '<div class="tr-card-left">' +
            '<div class="tr-reviewer-name">' +
              escHtml(r.name || 'Anonymous') +
              '<span class="tr-verified-badge">Verified</span>' +
            '</div>' +
            '<div class="tr-card-stars">' + makeStars(r.rating) + '</div>' +
          '</div>' +
          '<div class="tr-card-meta">' +
            (dateStr ? '<span>' + dateStr + '</span>' : '') +
            location +
          '</div>' +
        '</div>' +
        titleHtml +
        '<p class="tr-card-body">' + escHtml(r.body || '') + '</p>';

      listEl.appendChild(card);
    });
  }

  function escHtml(str) {
    return (str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function showEmpty() {
    var listEl = document.getElementById('tr-list-' + PRODUCT_ID);
    var emptyEl = document.getElementById('tr-empty-' + PRODUCT_ID);
    if (listEl) listEl.innerHTML = '';
    if (emptyEl) emptyEl.style.display = 'block';
  }

  function updateLoadMore() {
    var wrap = document.getElementById('tr-loadmore-wrap-' + PRODUCT_ID);
    if (!wrap) return;
    wrap.style.display = totalLoaded < totalAvailable ? 'block' : 'none';
  }

  function fetchReviews(page, append) {
    var url = BACKEND + '/api/public/reviews?handles=' + encodeURIComponent(HANDLES) + '&page=' + page + '&limit=' + LIMIT;

    fetch(url)
      .then(function(r) { return r.json(); })
      .then(function(json) {
        if (!json.success || !json.data) return showEmpty();
        var data = json.data;
        totalAvailable = data.summary.total;

        if (!append) {
          renderSummary(data.summary);
          renderBreakdown(data.summary);
        }

        if (data.reviews.length === 0 && !append) {
          showEmpty();
          return;
        }

        renderReviews(data.reviews, append);
        totalLoaded += data.reviews.length;
        updateLoadMore();
      })
      .catch(function() {
        var listEl = document.getElementById('tr-list-' + PRODUCT_ID);
        if (listEl) listEl.innerHTML = '<p style="color:#555;font-size:14px;padding:20px 0;">Could not load reviews. Please refresh the page.</p>';
      });
  }

  // Load More button
  var loadMoreBtn = document.getElementById('tr-loadmore-' + PRODUCT_ID);
  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', function() {
      PAGE++;
      loadMoreBtn.textContent = 'Loading...';
      loadMoreBtn.disabled = true;
      fetchReviews(PAGE, true);
      setTimeout(function() {
        loadMoreBtn.textContent = 'Load More Reviews';
        loadMoreBtn.disabled = false;
      }, 1200);
    });
  }

  // Initial load
  fetchReviews(1, false);
})();
</script>
