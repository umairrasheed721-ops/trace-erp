{%- comment -%}
  trace-reviews.liquid
  
  Custom TRACE review widget.
  Fetches reviews from our backend API — no Judge.me dependency.

  Usage in product template:
    {% render 'trace-reviews',
       product: product,
       linked_handles: 'texture-white,texture-black,texture-navy',
       combined: true
    %}
  
  If combined is false (default), only this product's reviews are shown.
{%- endcomment -%}

{%- assign _backend_url = 'https://trace-erp-production.up.railway.app' -%}
{%- assign _this_handle = product.handle | default: '' -%}
{%- assign _product_id = product.id | default: 'global' -%}
{%- assign _layout_type = layout_type | default: 'list' -%}
{%- assign _title = title | default: 'Customer Reviews' -%}

{%- comment -%} Build handles list for API call {%- endcomment -%}
{%- if combined and linked_handles != blank -%}
  {%- assign _all_handles = linked_handles -%}
  {%- unless _all_handles contains _this_handle -%}
    {%- assign _all_handles = _this_handle | append: ',' | append: _all_handles -%}
  {%- endunless -%}
{%- else -%}
  {%- assign _all_handles = _this_handle -%}
{%- endif -%}

<section class="trace-reviews-section tr-layout-{{ _layout_type }}" id="trace-reviews-{{ _product_id }}" aria-label="Customer Reviews">
  <div class="trace-reviews-wrap">

    <h2 class="tr-title">{{ _title }}</h2>

    {%- unless _layout_type == 'carousel' -%}
    <!-- Centered Summary Box -->
    <div class="tr-summary-box" id="tr-summary-grid-{{ _product_id }}">
      <div class="tr-summary-score-wrap" id="tr-summary-{{ _product_id }}">
        <!-- Skeleton before loading -->
        <div class="tr-skeleton-line" style="width:120px;height:48px;margin-bottom:8px;margin: 0 auto;"></div>
        <div class="tr-skeleton-line" style="width:180px;height:20px;margin: 0 auto;"></div>
      </div>
    </div>
    {%- endunless -%}

    {%- if _layout_type == 'carousel' -%}
    <!-- Carousel Layout -->
    <div class="tr-carousel-viewport">
      <div class="tr-reviews-list" id="tr-list-{{ _product_id }}">
        <div class="tr-loading">
          <div class="tr-spinner"></div>
          <span>Loading reviews...</span>
        </div>
      </div>
    </div>
    <div class="tr-carousel-dots" id="tr-dots-{{ _product_id }}"></div>
    {%- else -%}
    <!-- List Layout -->
    <div class="tr-reviews-list" id="tr-list-{{ _product_id }}">
      <div class="tr-loading">
        <div class="tr-spinner"></div>
        <span>Loading reviews...</span>
      </div>
    </div>
    {%- endif -%}

    {%- unless _layout_type == 'carousel' -%}
    <!-- Load More -->
    <div class="tr-load-more-wrap" id="tr-loadmore-wrap-{{ _product_id }}" style="display:none;">
      <button class="tr-load-more-btn" id="tr-loadmore-{{ _product_id }}">Load More Reviews</button>
    </div>
    {%- endunless -%}

    <!-- Empty State -->
    <div class="tr-empty" id="tr-empty-{{ _product_id }}" style="display:none;">
      <div class="tr-empty-stars">★ ★ ★ ★ ★</div>
      <p class="tr-empty-title">{{ _title }}</p>
      <p class="tr-empty-text">No reviews yet. Be the first to review this product!</p>
    </div>

  </div>
</section>

<style>
/* ── TRACE Reviews Widget Color Tokens ── */
:root {
  --tr-text-color: #121212;
  --tr-text-muted: #767676;
  --tr-star-color: #ffb400; /* Premium Gold */
  --tr-star-empty-color: #e5e5e5; /* Light grey for empty stars */
  --tr-card-bg: #ffffff;
  --tr-card-border: #f0f0f0;
  --tr-card-shadow: 0 4px 12px rgba(0, 0, 0, 0.02);
  --tr-border-color: #f0f0f0;
}

.trace-reviews-section {
  padding: 20px 0;
  border-top: 1px solid var(--tr-border-color);
  margin-top: 20px;
  background: transparent;
}

.trace-reviews-wrap {
  max-width: 820px;
  margin: 0 auto;
  padding: 0 20px;
}

.tr-title {
  font-size: 22px;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin: 0 0 20px;
  color: var(--tr-text-color);
  text-align: left;
}

/* Centered Summary Box */
.tr-summary-box {
  background: #ffffff;
  border: 1px solid var(--tr-card-border);
  padding: 32px;
  border-radius: 16px;
  margin-bottom: 24px;
  box-shadow: var(--tr-card-shadow);
  display: none;
  justify-content: center;
  align-items: center;
}

.tr-summary-score-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  text-align: center;
}

.tr-avg-score {
  font-size: 56px;
  font-weight: 900;
  line-height: 1;
  color: var(--tr-text-color);
}

.tr-avg-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}

.tr-stars-row {
  display: flex;
  gap: 3px;
}

/* Stars Styling */
.tr-star-filled, .tr-card-star-filled {
  color: var(--tr-star-color);
  font-size: 20px;
}
.tr-star-empty, .tr-card-star-empty {
  color: var(--tr-star-empty-color);
  font-size: 20px;
}
.tr-star-half {
  position: relative;
  display: inline-block;
  color: var(--tr-star-empty-color);
  font-size: 20px;
}
.tr-star-half::before {
  content: '★';
  position: absolute;
  left: 0;
  top: 0;
  width: 50%;
  overflow: hidden;
  color: var(--tr-star-color);
}

.tr-total-count {
  font-size: 13px;
  font-weight: 500;
  color: var(--tr-text-muted);
  letter-spacing: 0.5px;
}

/* Review Cards List */
.tr-reviews-list {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.tr-review-card {
  background: var(--tr-card-bg);
  border: 1px solid var(--tr-card-border);
  border-radius: 14px;
  padding: 24px;
  box-shadow: var(--tr-card-shadow);
  transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  animation: trFadeIn 0.4s ease both;
}
.tr-review-card:hover {
  transform: translateY(-2px);
  border-color: rgba(0,0,0,0.08);
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.04);
}

@keyframes trFadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

.tr-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}

.tr-card-left {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.tr-reviewer-name {
  font-size: 15px;
  font-weight: 700;
  color: var(--tr-text-color);
  display: flex;
  align-items: center;
  gap: 8px;
}

.tr-verified-badge {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.5px;
  background: #ecfdf5;
  color: #10b981;
  border: 1px solid #d1fae5;
  border-radius: 99px;
  padding: 2px 8px;
  text-transform: uppercase;
}

.tr-card-stars {
  display: flex;
  gap: 2px;
}
.tr-card-star-filled {
  color: var(--tr-star-color);
  font-size: 14px;
}
.tr-card-star-empty {
  color: var(--tr-star-empty-color);
  font-size: 14px;
}

.tr-card-meta {
  font-size: 13px;
  color: var(--tr-text-muted);
  display: flex;
  gap: 8px;
  align-items: center;
}
.tr-meta-sep {
  color: #ddd;
}

.tr-card-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--tr-text-color);
  margin: 0 0 8px;
}

.tr-card-body {
  font-size: 14px;
  line-height: 1.65;
  color: #4a4a4a;
  margin: 0;
  white-space: pre-wrap;
  word-break: break-word;
}

/* Loading Spinner */
.tr-loading {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 32px 0;
  color: var(--tr-text-muted);
  font-size: 14px;
  justify-content: center;
}

.tr-spinner {
  width: 20px;
  height: 20px;
  border: 2px solid rgba(0,0,0,0.05);
  border-top-color: var(--tr-text-color);
  border-radius: 50%;
  animation: trSpin 0.8s linear infinite;
  flex-shrink: 0;
}
@keyframes trSpin { to { transform: rotate(360deg); } }

/* Skeleton */
.tr-skeleton-line {
  background: linear-gradient(90deg, rgba(0,0,0,0.03) 25%, rgba(0,0,0,0.06) 50%, rgba(0,0,0,0.03) 25%);
  background-size: 200% 100%;
  animation: trShimmer 1.5s infinite;
  border-radius: 4px;
}
@keyframes trShimmer { to { background-position: -200% 0; } }

/* Load More Button */
.tr-load-more-wrap {
  text-align: center;
  margin-top: 28px;
}
.tr-load-more-btn {
  background: transparent;
  border: 1px solid rgba(0,0,0,0.15);
  color: var(--tr-text-color);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  padding: 13px 32px;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.2s;
}
.tr-load-more-btn:hover {
  border-color: var(--tr-text-color);
  background: rgba(0,0,0,0.02);
}

/* Premium Empty State */
.tr-empty {
  text-align: center;
  padding: 64px 32px;
  background: #ffffff;
  border: 1px solid var(--tr-card-border);
  border-radius: 16px;
  box-shadow: var(--tr-card-shadow);
}
.tr-empty-stars {
  font-size: 24px;
  color: var(--tr-star-empty-color);
  margin-bottom: 16px;
  letter-spacing: 4px;
}
.tr-empty-title {
  font-size: 16px;
  font-weight: 700;
  color: var(--tr-text-color);
  margin: 0 0 8px;
  text-transform: uppercase;
  letter-spacing: 1px;
}
.tr-empty-text {
  font-size: 14px;
  margin: 0;
  color: var(--tr-text-muted);
}

/* Responsive adjustments */
@media (max-width: 640px) {
  .tr-avg-score { font-size: 48px; }
  .tr-review-card { padding: 18px; }
}

/* ── Carousel Layout Styles ── */
.tr-layout-carousel {
  padding: 60px 0;
  background: #fafafa;
  border-top: 1px solid var(--tr-border-color);
  border-bottom: 1px solid var(--tr-border-color);
  margin: 40px 0;
}
.tr-layout-carousel .tr-title {
  text-align: center;
  font-family: 'Playfair Display', 'Didot', 'Georgia', serif;
  text-transform: none;
  font-weight: 500;
  font-size: 36px;
  letter-spacing: 0.5px;
  margin-bottom: 48px;
  color: var(--tr-text-color);
}

.tr-layout-carousel .tr-carousel-viewport {
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  -ms-overflow-style: none;
  padding: 20px 0;
}

.tr-layout-carousel .tr-carousel-viewport::-webkit-scrollbar {
  display: none;
}

.tr-layout-carousel .tr-reviews-list {
  display: flex;
  flex-direction: row;
  gap: 24px;
  width: max-content;
  padding: 0 40px;
}

.tr-layout-carousel .tr-review-card {
  width: 320px;
  min-height: 280px;
  flex-shrink: 0;
  scroll-snap-align: center;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 40px 32px;
  border-radius: 8px;
  background: #ffffff;
  border: 1px solid var(--tr-card-border);
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.03);
  position: relative;
  overflow: hidden;
}

/* Faint quote mark in the background */
.tr-layout-carousel .tr-review-card::before {
  content: '“';
  position: absolute;
  top: 10px;
  left: 20px;
  font-size: 110px;
  font-family: 'Playfair Display', 'Didot', 'Georgia', serif;
  color: rgba(0, 0, 0, 0.035);
  line-height: 1;
  pointer-events: none;
}

.tr-layout-carousel .tr-card-stars {
  font-size: 18px;
  margin-bottom: 24px;
  display: flex;
  justify-content: center;
  gap: 4px;
  position: relative;
  z-index: 1;
}

.tr-layout-carousel .tr-card-star-filled {
  color: var(--tr-star-color);
}

.tr-layout-carousel .tr-card-star-empty {
  color: var(--tr-star-empty-color);
}

.tr-layout-carousel .tr-card-body {
  font-size: 14px;
  line-height: 1.8;
  color: #4a4a4a;
  margin: 0 0 28px;
  font-weight: 400;
  display: -webkit-box;
  -webkit-line-clamp: 5;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  position: relative;
  z-index: 1;
}

.tr-layout-carousel .tr-card-author-wrap {
  margin-top: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  position: relative;
  z-index: 1;
}

.tr-layout-carousel .tr-reviewer-name {
  font-size: 15px;
  font-weight: 700;
  color: var(--tr-text-color);
  letter-spacing: 0.2px;
}

.tr-layout-carousel .tr-card-location {
  font-size: 13px;
  color: var(--tr-text-muted);
  text-transform: capitalize;
  letter-spacing: 0.5px;
}

/* Dots Pagination */
.tr-carousel-dots {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-top: 24px;
}

.tr-carousel-dots .tr-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #e5e5e5;
  cursor: pointer;
  transition: all 0.3s ease;
}

.tr-carousel-dots .tr-dot.active {
  background: #121212;
  transform: scale(1.2);
}

@media (max-width: 640px) {
  .tr-layout-carousel .tr-reviews-list {
    padding: 0 16px;
  }
  .tr-layout-carousel .tr-review-card {
    width: calc(100vw - 32px) !important;
    padding: 28px 20px;
  }
}
</style>

<script>
(function() {
  var BACKEND = 'https://trace-erp-production.up.railway.app';
  var HANDLES = '{{ _all_handles | escape }}';
  var PRODUCT_ID = '{{ _product_id }}';
  var LAYOUT_TYPE = '{{ _layout_type }}';
  var PAGE = 1;
  var LIMIT = 10;
  var totalLoaded = 0;
  var totalAvailable = 0;

  function makeStars(rating) {
    var html = '';
    for (var i = 1; i <= 5; i++) {
      if (i <= rating) {
        html += '<span class="tr-card-star-filled">★</span>';
      } else {
        html += '<span class="tr-card-star-empty">★</span>';
      }
    }
    return html;
  }

  function makeSummaryStars(avg) {
    var html = '';
    for (var i = 1; i <= 5; i++) {
      if (avg >= i) {
        html += '<span class="tr-star-filled">★</span>';
      } else if (avg >= i - 0.5) {
        html += '<span class="tr-star-half">★</span>';
      } else {
        html += '<span class="tr-star-empty">★</span>';
      }
    }
    return html;
  }

  function formatDate(dateStr) {
    if (!dateStr) return '';
    try {
      var d = new Date(dateStr);
      return d.toLocaleDateString('en-PK', { year: 'numeric', month: 'short', day: 'numeric' });
    } catch(e) { return ''; }
  }

  function renderSummary(summary) {
    var summaryEl = document.getElementById('tr-summary-' + PRODUCT_ID);
    var gridEl = document.getElementById('tr-summary-grid-' + PRODUCT_ID);
    if (!summaryEl) return;

    if (!summary || summary.total === 0) {
      if (gridEl) gridEl.style.display = 'none';
      return;
    }

    if (gridEl) gridEl.style.display = 'flex';

    summaryEl.innerHTML =
      '<div class="tr-avg-score">' + (summary.avg || 0).toFixed(1) + '</div>' +
      '<div class="tr-avg-right">' +
        '<div class="tr-stars-row">' + makeSummaryStars(summary.avg || 0) + '</div>' +
        '<div class="tr-total-count">Based on ' + summary.total + ' review' + (summary.total !== 1 ? 's' : '') + '</div>' +
      '</div>';
  }

  function renderReviews(reviews, append) {
    var listEl = document.getElementById('tr-list-' + PRODUCT_ID);
    if (!listEl) return;

    if (!append) listEl.innerHTML = '';

    reviews.forEach(function(r, idx) {
      var card = document.createElement('div');
      card.className = 'tr-review-card';
      card.style.animationDelay = (idx * 0.05) + 's';

      var dateStr = formatDate(r.date);
      var locationHtml = '<div class="tr-card-location">' + escHtml(r.location || 'Pakistan') + '</div>';

      if (LAYOUT_TYPE === 'carousel') {
        card.innerHTML =
          '<div class="tr-card-stars">' + makeStars(r.rating) + '</div>' +
          '<p class="tr-card-body">' + escHtml(r.body || '') + '</p>' +
          '<div class="tr-card-author-wrap">' +
            '<div class="tr-reviewer-name">' + escHtml(r.name || 'Anonymous') + '</div>' +
            locationHtml +
          '</div>';
      } else {
        var location = r.location ? ('<span class="tr-meta-sep">·</span><span>' + r.location + '</span>') : '';
        var titleHtml = r.title ? '<p class="tr-card-title">' + escHtml(r.title) + '</p>' : '';
        card.innerHTML =
          '<div class="tr-card-top">' +
            '<div class="tr-card-left">' +
              '<div class="tr-reviewer-name">' +
                escHtml(r.name || 'Anonymous') +
                '<span class="tr-verified-badge">Verified</span>' +
              '</div>' +
              '<div class="tr-card-stars">' + makeStars(r.rating) + '</div>' +
            '</div>' +
            '<div class="tr-card-meta">' +
              (dateStr ? '<span>' + dateStr + '</span>' : '') +
              location +
            '</div>' +
          '</div>' +
          titleHtml +
          '<p class="tr-card-body">' + escHtml(r.body || '') + '</p>';
      }

      listEl.appendChild(card);
    });

    if (LAYOUT_TYPE === 'carousel' && !append) {
      initCarousel();
    }
  }

  // Escape HTML helper
  function escHtml(str) {
    return (str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function showEmpty() {
    var listEl = document.getElementById('tr-list-' + PRODUCT_ID);
    var gridEl = document.getElementById('tr-summary-grid-' + PRODUCT_ID);
    var emptyEl = document.getElementById('tr-empty-' + PRODUCT_ID);
    if (listEl) listEl.innerHTML = '';
    if (gridEl) gridEl.style.display = 'none';
    if (emptyEl) emptyEl.style.display = 'block';
  }

  function updateLoadMore() {
    var wrap = document.getElementById('tr-loadmore-wrap-' + PRODUCT_ID);
    if (!wrap) return;
    wrap.style.display = totalLoaded < totalAvailable ? 'block' : 'none';
  }

  function initCarousel() {
    var viewportEl = document.querySelector('#trace-reviews-' + PRODUCT_ID + ' .tr-carousel-viewport');
    var listEl = document.getElementById('tr-list-' + PRODUCT_ID);
    var dotsEl = document.getElementById('tr-dots-' + PRODUCT_ID);
    if (!viewportEl || !listEl || !dotsEl) return;

    var cards = listEl.querySelectorAll('.tr-review-card');
    if (cards.length === 0) return;

    var cardWidth = cards[0].offsetWidth;
    var gap = 24;
    var dots = [];

    function setupDots() {
      dotsEl.innerHTML = '';
      dots = [];
      
      var viewportWidth = viewportEl.offsetWidth;
      var cardsPerPage = Math.max(1, Math.floor((viewportWidth + gap) / (cardWidth + gap)));
      var numPages = Math.ceil(cards.length / cardsPerPage);

      for (var i = 0; i < numPages; i++) {
        var dot = document.createElement('span');
        dot.className = 'tr-dot' + (i === 0 ? ' active' : '');
        dot.dataset.page = i;
        dot.addEventListener('click', function(e) {
          var pageIdx = parseInt(e.target.dataset.page);
          scrollToPage(pageIdx, cardsPerPage);
        });
        dotsEl.appendChild(dot);
        dots.push(dot);
      }
    }

    function scrollToPage(pageIdx, cardsPerPage) {
      var cardIndex = pageIdx * cardsPerPage;
      if (cardIndex >= cards.length) {
        cardIndex = cards.length - 1;
      }
      var card = cards[cardIndex];
      if (!card) return;
      
      var scrollLeftOffset = card.offsetLeft - 40;
      if (scrollLeftOffset < 0) scrollLeftOffset = 0;

      viewportEl.scrollTo({
        left: scrollLeftOffset,
        behavior: 'smooth'
      });
    }

    var scrollTimeout;
    viewportEl.addEventListener('scroll', function() {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(updateActiveDot, 50);
    });

    function updateActiveDot() {
      var viewportWidth = viewportEl.offsetWidth;
      var cardsPerPage = Math.max(1, Math.floor((viewportWidth + gap) / (cardWidth + gap)));
      
      var scrollFraction = viewportEl.scrollLeft / (cardWidth + gap);
      var currentPage = Math.round(scrollFraction / cardsPerPage);

      dots.forEach(function(dot, idx) {
        if (idx === currentPage) {
          dot.classList.add('active');
        } else {
          dot.classList.remove('active');
        }
      });
    }

    setupDots();
    
    var resizeTimeout;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(setupDots, 150);
    });
  }

  function fetchReviews(page, append) {
    var url = BACKEND + '/api/public/reviews?handles=' + encodeURIComponent(HANDLES) + '&page=' + page + '&limit=' + LIMIT;

    fetch(url)
      .then(function(r) { return r.json(); })
      .then(function(json) {
        if (!json.success || !json.data) return showEmpty();
        var data = json.data;
        totalAvailable = data.summary.total;

        if (!append) {
          renderSummary(data.summary);
        }

        if (data.reviews.length === 0 && !append) {
          showEmpty();
          return;
        }

        renderReviews(data.reviews, append);
        totalLoaded += data.reviews.length;
        updateLoadMore();
      })
      .catch(function() {
        var listEl = document.getElementById('tr-list-' + PRODUCT_ID);
        if (listEl) listEl.innerHTML = '<p style="color:#767676;font-size:14px;padding:20px 0;text-align:center;">Could not load reviews. Please refresh the page.</p>';
      });
  }

  // Load More button
  var loadMoreBtn = document.getElementById('tr-loadmore-' + PRODUCT_ID);
  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', function() {
      PAGE++;
      loadMoreBtn.textContent = 'Loading...';
      loadMoreBtn.disabled = true;
      fetchReviews(PAGE, true);
      setTimeout(function() {
        loadMoreBtn.textContent = 'Load More Reviews';
        loadMoreBtn.disabled = false;
      }, 1200);
    });
  }

  // Initial load
  fetchReviews(1, false);
})();
</script>
