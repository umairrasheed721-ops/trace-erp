{% comment %}
  TRACEPK CUSTOM COLLECTION CARD (DAWN 15.4.1)
  Includes Size Pills, Image Color Swatches with strict inventory hiding, and Top-Positioned Bundle Promo Box.
{% endcomment %}

{%- unless skip_styles -%}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-volume-pricing.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'quick-order-list.css' | asset_url | stylesheet_tag }}
  {{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

<style>
  .trace-card-swatches {
    margin-top: 12px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  /* Size Pills Style */
  .trace-size-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .trace-size-pill {
    font-size: 10px;
    padding: 2px 6px;
    border: 1px solid #e0e0e0;
    color: #666;
    border-radius: 2px;
    text-transform: uppercase;
  }
  /* Color Swatches Style */
  .trace-color-swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .trace-color-swatch {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 1px solid #e0e0e0;
    background-size: cover;
    background-position: center;
    position: relative;
    cursor: pointer;
  }
  .trace-color-swatch:hover {
    border-color: #000;
  }
</style>

{%- if card_product and card_product != empty -%}
  {%- liquid
    assign ratio = 1
    if card_product.featured_media and media_aspect_ratio == 'portrait'
      assign ratio = 0.8
    elsif card_product.featured_media and media_aspect_ratio == 'adapt'
      assign ratio = card_product.featured_media.aspect_ratio
    endif
  -%}
  <div class="card-wrapper product-card-wrapper underline-links-hover">
    <div class="card card--{{ settings.card_style }} {% if card_product.featured_media %} card--media{% else %} card--text{% endif %} style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;">
      
      {%- comment -%} IMAGE AREA {%- endcomment -%}
      <div class="card__inner {% if settings.card_style == 'standard' %}color-{{ settings.card_color_scheme }} gradient{% endif %} ratio" style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;">
        {%- if card_product.featured_media -%}
          <div class="card__media">
            <div class="media media--transparent media--hover-effect">
              <img srcset="{%- if card_product.featured_media.width >= 165 -%}{{ card_product.featured_media | image_url: width: 165 }} 165w,{%- endif -%} {{ card_product.featured_media | image_url }} {{ card_product.featured_media.width }}w"
                src="{{ card_product.featured_media | image_url: width: 533 }}"
                sizes="(min-width: 1200px) 25vw, (min-width: 750px) 33vw, 50vw"
                alt="{{ card_product.featured_media.alt | escape }}"
                class="motion-reduce" loading="lazy" width="{{ card_product.featured_media.width }}" height="{{ card_product.featured_media.height }}">
            </div>
          </div>
        {%- endif -%}
        
        <div class="card__content">
          <div class="card__badge {{ settings.badge_position }}">
            {%- if card_product.available == false -%}
              <span class="badge color-{{ settings.sold_out_badge_color_scheme }}">{{ 'products.product.sold_out' | t }}</span>
            {%- elsif card_product.compare_at_price > card_product.price -%}
              <span class="badge color-{{ settings.sale_badge_color_scheme }}">{{ 'products.product.on_sale' | t }}</span>
            {%- endif -%}
          </div>
        </div>
      </div>

      {%- comment -%} INFO AREA {%- endcomment -%}
      <div class="card__content">
        <div class="card__information">

          {%- comment -%} --- TRACEPK BUNDLE PROMO BOX (TOP POSITION) --- {%- endcomment -%}
          {%- if card_product.tags contains 'bundle_active' -%}
            {%- assign discount_amount = 500 -%}
            {%- if card_product.metafields.custom.bundle_discount -%}
              {%- assign discount_amount = card_product.metafields.custom.bundle_discount.value | plus: 0 -%}
            {%- endif -%}
            {%- assign discount_in_cents = discount_amount | times: 100 -%}
            {%- assign two_pack_original_price = card_product.price | times: 2 -%}
            {%- assign two_pack_bundle_price = two_pack_original_price | minus: discount_in_cents -%}
            {%- assign per_item_price = two_pack_bundle_price | divided_by: 2 -%}

            {%- if card_product.available and two_pack_original_price > discount_in_cents -%}
            <div style="background-color: #111; padding: 10px; margin-bottom: 12px; border-radius: 6px; text-align: center; box-shadow: 0 4px 10px rgba(0,0,0,0.08);">
              <div style="font-weight: 900; color: #fff; font-size: 0.95rem; line-height: 1.2; letter-spacing: 0.5px;">
                🎁 2-PACK DEAL: {{ two_pack_bundle_price | money }}
              </div>
              <div style="color: #4ade80; font-weight: 800; font-size: 0.8rem; margin-top: 4px; text-transform: uppercase;">
                ↳ Just {{ per_item_price | money }} per item
              </div>
            </div>
            {%- endif -%}
          {%- endif -%}
          {%- comment -%} --- END TRACEPK BUNDLE PROMO BOX --- {%- endcomment -%}

          <h3 class="card__heading h5">
            <a href="{{ card_product.url }}" class="full-unstyled-link">{{ card_product.title | escape }}</a>
          </h3>

          {%- comment -%} TRACE Star Rating Badge {%- endcomment -%}
          <div class="trace-card-rating" data-handle="{{ card_product.handle }}" style="margin:4px 0 8px;display:flex;align-items:center;gap:5px;min-height:18px;">
          </div>
          
          <div class="card-information">
            {% render 'price', product: card_product, show_compare_at_price: true %}

            {%- comment -%} TRACEPK SWATCH BRAIN STARTS HERE {%- endcomment -%}
            <div class="trace-card-swatches">
              
              {%- comment -%} 1. SIZE PILLS (Hide if Sold Out) {%- endcomment -%}
              {%- for option in card_product.options_with_values -%}
                {%- if option.name == 'Size' or option.name == 'size' -%}
                  <div class="trace-size-pills">
                    {%- for value in option.values -%}
                      {%- liquid
                        assign size_available = false
                        for variant in card_product.variants
                          if variant.options contains value and variant.available
                            assign size_available = true
                            break
                          endif
                        endfor
                      -%}
                      {%- if size_available -%}
                        <span class="trace-size-pill">{{ value }}</span>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              {%- endfor -%}

              {%- comment -%} 2. COLOR CIRCLES (Hide if Sold Out) {%- endcomment -%}
              {%- for option in card_product.options_with_values -%}
                {%- if option.name == 'Color' or option.name == 'Colour' or option.name == 'color' -%}
                  <div class="trace-color-swatches">
                    {%- for value in option.values -%}
                      {%- liquid
                        assign color_variant = blank
                        assign color_available = false
                        for variant in card_product.variants
                          if variant.options contains value
                            if variant.available
                              assign color_available = true
                              assign color_variant = variant
                              break
                            endif
                          endif
                        endfor
                      -%}
                      {%- if color_available -%}
                        <a href="{{ card_product.url }}?variant={{ color_variant.id }}" 
                           class="trace-color-swatch" 
                           style="background-image: url({{ color_variant.featured_media | image_url: width: 50 }});"
                           title="{{ value }}">
                        </a>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
            {%- comment -%} TRACEPK SWATCH BRAIN ENDS {%- endcomment -%}

          </div>
        </div>
      </div>
    </div>
  </div>
{%- endif -%}