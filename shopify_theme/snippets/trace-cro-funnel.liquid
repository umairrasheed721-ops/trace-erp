<script>
document.addEventListener('DOMContentLoaded', function() {
  
  // ⚡ TRACE CSS TRAP FIX ⚡
  var stickyBarEl = document.getElementById('sticky-mobile-bundle-bar');
  var toastEl = document.getElementById('social-proof-toast');
  var sgModalEl = document.getElementById('size-guide-modal');
  var waModalEl = document.getElementById('whatsapp-checkout-modal');
  if (stickyBarEl) document.body.appendChild(stickyBarEl);
  if (toastEl) document.body.appendChild(toastEl);
  if (sgModalEl) document.body.appendChild(sgModalEl);
  if (waModalEl) document.body.appendChild(waModalEl);

  var errorMsgBox = document.getElementById('master-error-msg');
  var downgradeMsgBox = document.getElementById('downgrade-msg');
  var addCartBtn = document.getElementById('master-add-cart-btn');
  var buyNowBtn = document.getElementById('master-buy-now-btn');
  var bundleWrapper = document.getElementById('master-funnel-wrapper'); 

  var progressBar = document.getElementById('bundle-progress-bar');
  var progressText = document.getElementById('progress-text');
  var progressPercent = document.getElementById('progress-percentage');
  var stickyBar = document.getElementById('sticky-mobile-bundle-bar');
  var stickyBtn = document.getElementById('sticky-unlock-btn');

  var waSubmitBtn = document.getElementById('wa-submit-btn');

  var isSplitSize = false;
  var hasAutoScrolledForSize = false;

  // ⚡ AI-FRIENDLY CONFIGURATION ACCESS ⚡
  var cfg = window.TRACE_CONFIG;

  // Helper: Format Money in JS
  function formatMoney(amount) {
      return 'Rs. ' + amount.toLocaleString('en-US') + '.00';
  }

  // ⚡ 1. ADVANCE-ONLY LOCKOUT LOGIC ⚡
  if (cfg.isAdvanceOnly) {
      var codCard = document.getElementById('cod-payment-card');
      var codInput = codCard.querySelector('input');
      var codPrice = document.getElementById('cod-price-text');
      var codBadge = document.getElementById('cod-locked-badge');
      var advInput = document.querySelector('input[name="payment-method"][value="advance"]');
      var warningMsg = document.getElementById('advance-warning-msg');
      
      codInput.disabled = true;
      codCard.style.opacity = '0.5';
      codCard.style.pointerEvents = 'none';
      codPrice.style.textDecoration = 'line-through';
      codBadge.style.display = 'inline-flex';
      if(warningMsg) warningMsg.style.display = 'flex';
      
      advInput.checked = true; 
  }

  // ⚡ INVENTORY AWARENESS ENGINE ⚡
  var variants = cfg.variants;
  var availableSizes = {};
  var availableColors = {};
  var deadColors = {};
  var allColors = {};
  
  variants.forEach(function(v) { 
    var s = v[cfg.sizeKey];
    if (v.available) { 
      availableSizes[s] = true; 
    } 
    if (cfg.colorKey) {
      var c = v[cfg.colorKey]; 
      allColors[c] = true; 
      if (v.available) { 
        availableColors[c] = true; 
      } 
    }
  });
  
  document.querySelectorAll('.size-wrapper-pill').forEach(function(el) { 
    if(!availableSizes[el.getAttribute('data-value')]) el.style.display = 'none'; 
  });
  if (cfg.colorKey) {
    document.querySelectorAll('.swatch-wrapper').forEach(function(el) { 
      if(!availableColors[el.getAttribute('data-value')]) el.style.display = 'none'; 
    });
  }
  
  if (cfg.colorKey) {
    Object.keys(allColors).forEach(function(c) { 
      if(!availableColors[c]) deadColors[c] = true; 
    });
  }
  
  if(cfg.colorKey && Object.keys(deadColors).length > 0) {
    var deadImages = {};
    variants.forEach(function(v) { 
      if(deadColors[v[cfg.colorKey]] && v.featured_image) {
        var cleanName = v.featured_image.src.split('?')[0].split('/').pop().replace(/\.(jpg|jpeg|png|gif|webp)/i, '');
        deadImages[cleanName] = true; 
      }
    });
    document.querySelectorAll('img').forEach(function(img) { 
      Object.keys(deadImages).forEach(function(dSrc) { 
        if(img.src.indexOf(dSrc) !== -1) { 
          var li = img.closest('li.thumbnail-list__item, li.product__media-item, .product-media-container'); 
          if(li) li.style.display = 'none'; 
        } 
      }); 
    });
  }

  function getAvailableColorsForSize(size) {
    if(!size) return [];
    var colors = [];
    variants.forEach(function(v) {
      if(v[cfg.sizeKey] === size && v.available) {
        if(colors.indexOf(v[cfg.colorKey]) === -1) colors.push(v[cfg.colorKey]);
      }
    });
    return colors;
  }

  function canFulfillUniqueColors(sizesArr) {
    if (!cfg.colorKey) return true;
    var uniqueAvailableColors = new Set();
    sizesArr.forEach(function(sz) {
      getAvailableColorsForSize(sz).forEach(function(c) {
        uniqueAvailableColors.add(c);
      });
    });
    return uniqueAvailableColors.size >= sizesArr.length;
  }

  function evaluateBundleLocks() {
    if(cfg.hideBundles) return; // Skip if bundles are hidden

    var activeDealInput = document.querySelector('input[name="master-deal"]:checked');
    if(!activeDealInput) return;
    var activeDeal = activeDealInput.value;
    var downgraded = false;
    var downgradeTo = activeDeal;

    [4, 3, 2].forEach(function(tier) {
      var tierInput = document.querySelector('input[name="master-deal"][value="bundle' + (tier === 2 ? '' : tier) + '"]');
      if(!tierInput) return;
      var card = tierInput.closest('.package-card');
      
      var sizesToTest = [];
      if (!isSplitSize) {
        var globalSize = document.querySelector('input[name="master-size"]:checked');
        if (globalSize) {
          for(var i = 0; i < tier; i++) sizesToTest.push(globalSize.value);
        }
      } else {
        for(var j = 1; j <= tier; j++) {
          var sz = document.querySelector('input[name="size-' + j + '"]:checked');
          if(sz) sizesToTest.push(sz.value);
        }
      }

      var isLocked = sizesToTest.length > 0 && !canFulfillUniqueColors(sizesToTest);
      var badge = card.querySelector('.tier-badge');
      var saveText = card.querySelector('.pulse-save-badge') || card.querySelector('.tier-save-text');

      if (isLocked) {
        card.style.opacity = '0.5';
        card.style.pointerEvents = 'none';
        tierInput.disabled = true;
        
        if(badge) {
            badge.innerHTML = '🔒 LOCKED';
            badge.style.background = '#888';
            badge.style.display = 'inline-block';
        }
        if(saveText) {
            saveText.innerHTML = 'Not enough unique colors';
            saveText.style.background = '#f1f1f1';
            saveText.style.color = '#666';
            saveText.classList.remove('pulse-save-badge');
            saveText.classList.add('tier-save-text');
        }
        
        if(tierInput.checked) {
            tierInput.checked = false;
            downgraded = true;
        }
      } else {
        card.style.opacity = '1';
        card.style.pointerEvents = 'auto';
        tierInput.disabled = false;
        
        if(badge) {
            var origTxt = badge.getAttribute('data-orig-txt');
            badge.innerHTML = origTxt || '';
            badge.style.background = badge.getAttribute('data-orig-bg') || 'transparent';
            if(!origTxt) badge.style.display = 'none';
            else badge.style.display = 'inline-block';
        }
        if(saveText) {
            saveText.innerHTML = saveText.getAttribute('data-orig-txt');
            saveText.style.background = '#e3f2e8';
            saveText.style.color = '#1e7038';
            saveText.classList.add('pulse-save-badge');
            saveText.classList.remove('tier-save-text');
        }
        
        if(downgraded && (!downgradeTo || downgradeTo === 'single' || tier > (downgradeTo.replace('bundle','') || 2))) {
            downgradeTo = tierInput.value;
        }
      }
    });

    if (downgraded) {
        var newTarget = document.querySelector('input[name="master-deal"][value="' + downgradeTo + '"]');
        if(!newTarget || newTarget.disabled) newTarget = document.querySelector('input[name="master-deal"]:not([disabled])');
        
        if(newTarget) {
            newTarget.checked = true;
            if(downgradeMsgBox) {
                downgradeMsgBox.innerHTML = 'Adjusted package: Not enough unique colors in selected size(s).';
                downgradeMsgBox.style.display = 'block';
                setTimeout(function(){ downgradeMsgBox.style.display = 'none'; }, 5000);
            }
        }
        updateUI(false);
    }
  }

  var availableColorsCount = Object.keys(availableColors).length;
  var bundle4Input = document.querySelector('input[name="master-deal"][value="bundle4"]');
  var bundle3Input = document.querySelector('input[name="master-deal"][value="bundle3"]');
  if (cfg.colorKey) {
    if (availableColorsCount < 4 && bundle4Input) bundle4Input.closest('.package-card').style.display = 'none';
    if (availableColorsCount < 3 && bundle3Input) bundle3Input.closest('.package-card').style.display = 'none';
  }

  if (cfg.colorKey && availableColorsCount === 1) {
    var step3Container = document.getElementById('step-3-container');
    if(step3Container) step3Container.style.display = 'none';
    var singleColor = Object.keys(availableColors)[0];
    for(var i=1; i<=4; i++) {
      var colorRadio = document.querySelector('input[name="color-' + i + '"][value="' + singleColor.replace(/"/g, '\\"') + '"]');
      if(colorRadio) colorRadio.checked = true;
    }
  }

  setTimeout(function() {
    variants.forEach(function(v) {
      if(v.featured_image && v.featured_image.src) {
        var img = new Image(); 
        img.src = v.featured_image.src;
      }
    });
  }, 1000);

  function getRequiredItemCount() {
    var dealInput = document.querySelector('input[name="master-deal"]:checked');
    if(!dealInput) return 1;
    return cfg.pricing[dealInput.value] ? cfg.pricing[dealInput.value].qty : 1;
  }

  function updateFunnelState() {
    var dealInput = document.querySelector('input[name="master-deal"]:checked');
    if(!dealInput) return;
    var deal = dealInput.value;
    var reqCount = getRequiredItemCount();
    var isAdvance = document.querySelector('input[name="payment-method"]:checked').value === 'advance';
    
    var sizeScore = 0;
    if (!isSplitSize) {
      sizeScore = document.querySelector('input[name="master-size"]:checked') ? 1 : 0;
    } else {
      var sizesFound = 0;
      for (var i = 1; i <= reqCount; i++) {
        if (document.querySelector('input[name="size-' + i + '"]:checked')) sizesFound++;
      }
      sizeScore = sizesFound / reqCount;
    }

    var colorsFound = 0;
    for (var j = 1; j <= reqCount; j++) {
      if (document.querySelector('input[name="color-' + j + '"]:checked')) colorsFound++;
    }
    var colorScore = colorsFound / reqCount;

    var score = 0;
    if (sizeScore > 0) score += 33 * sizeScore;
    if (colorScore > 0) score += 67 * colorScore;
    score = Math.floor(score);
    if(score > 98) score = 100;

    progressBar.style.width = score + '%';
    progressPercent.innerText = score + '%';

    if(score === 100) {
      progressBar.style.backgroundColor = '#22c55e';
      progressPercent.style.color = '#22c55e';
      progressText.innerHTML = '🎉 <strong style="color: #22c55e;">All set! Your deal is locked.</strong>';

      if(!bundleWrapper.classList.contains('celebrated')) {
        bundleWrapper.classList.add('celebration-pulse');
        bundleWrapper.classList.add('celebrated');
        if (navigator.vibrate) navigator.vibrate([20, 50, 20]); 
        setTimeout(function() { bundleWrapper.classList.remove('celebration-pulse'); }, 1000);
      }
    } else {
      bundleWrapper.classList.remove('celebrated');
      progressBar.style.backgroundColor = '#111';
      progressPercent.style.color = '#888';
      progressText.innerHTML = deal !== 'single' ? 'Complete your selections (' + colorsFound + '/' + reqCount + ' items)' : 'Select size & color';
    }

    document.querySelectorAll('.payment-card').forEach(function(card) {
      card.classList.remove('active-payment', 'active-payment-advance');
    });
    var activePaymentCard = document.querySelector('input[name="payment-method"]:checked').closest('.payment-card');
    if(activePaymentCard) {
      if (isAdvance) {
        activePaymentCard.classList.add('active-payment-advance');
      } else {
        activePaymentCard.classList.add('active-payment');
      }
    }

    // ⚡ DYNAMIC MATH CALCULATION ⚡
    var tierObj = cfg.pricing[deal] || cfg.pricing.single;
    
    var currentSub = tierObj.sub;
    var currentTotal = isAdvance ? tierObj.sub : tierObj.cod;

    var subtotalStr = formatMoney(currentSub);
    var totalStr = formatMoney(currentTotal);
    var itemName = tierObj.qty > 1 ? tierObj.qty + ' Items' : '1 Item';
    var btnTextDesc = tierObj.qty > 1 ? 'Buy ' + tierObj.qty + '-Pack' : 'Buy 1 Item';
    
    var summarySub = document.getElementById('summary-subtotal');
    var summaryDcType = document.getElementById('summary-dc-type');
    var summaryDcAmt = document.getElementById('summary-dc-amount');
    var summaryTotal = document.getElementById('summary-total');
    var summaryItems = document.getElementById('summary-item-count');

    if(summarySub) summarySub.innerText = subtotalStr;
    if(summaryItems) summaryItems.innerText = itemName;
    if(summaryTotal) summaryTotal.innerText = totalStr;

    if(isAdvance) {
        if(summaryDcType) summaryDcType.innerText = 'Advance Payment';
        if(summaryDcAmt) {
            summaryDcAmt.innerText = 'FREE';
            summaryDcAmt.style.color = '#16a34a';
            summaryDcAmt.style.fontWeight = '800';
        }
    } else {
        if(summaryDcType) summaryDcType.innerText = 'Standard COD';
        if(summaryDcAmt) {
            summaryDcAmt.innerText = '+ Rs. ' + cfg.deliveryCharge;
            summaryDcAmt.style.color = '#555';
            summaryDcAmt.style.fontWeight = '600';
        }
    }

    if (isAdvance) {
      addCartBtn.style.display = 'none'; 
      buyNowBtn.style.backgroundColor = '#25D366'; 
      buyNowBtn.querySelector('.btn-text-content').innerHTML = '<span style="display:flex; align-items:center; justify-content:center; gap:8px;"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="color:#fff;"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.197 1.441 4.742 1.443 5.486 0 9.954-4.437 9.957-9.899.002-2.646-1.03-5.132-2.905-7.008C16.566 1.81 14.09 .78 11.52.784c-5.49 0-9.959 4.439-9.962 9.9-.001 2.01.52 3.843 1.507 5.433l-.976 3.564 3.659-.96c1.614.99 3.255 1.437 4.786 1.437zM17.42 15.3c-.3-.15-1.782-.88-2.057-.98-.275-.1-.475-.15-.675.15-.2.3-.775.98-.95 1.18-.175.2-.35.225-.65.075-.3-.15-1.267-.467-2.413-1.49-1.12-1-1.879-2.235-2.099-2.61-.22-.375-.023-.578.127-.728.135-.135.3-.35.45-.525.15-.175.2-.3.3-.5.1-.2.05-.375-.025-.525-.075-.15-.675-1.625-.925-2.225-.244-.589-.491-.51-.675-.52-.175-.01-.375-.01-.575-.01-.2 0-.525.075-.8 1.012-.275.938-1.05 2.1-1.15 2.288-.1.188-.2.338-.2.525 0 1.25.775 2.475.9 2.65a11.947 11.947 0 0 0 4.6 4.075c1.4.6 2.5.8 3.3.675.838-.125 1.787-.725 2.037-1.388.25-.662.25-1.225.175-1.388-.075-.162-.275-.262-.575-.412z"/></svg> Order via WhatsApp • ' + totalStr + '</span>';
    } else {
      addCartBtn.style.display = 'block'; 
      buyNowBtn.style.backgroundColor = '#111'; 
      buyNowBtn.querySelector('.btn-text-content').innerHTML = btnTextDesc + ' • ' + totalStr;
    }

    if(score === 100) {
      if(stickyBtn) {
        stickyBtn.innerText = isAdvance ? 'Order via WhatsApp' : 'Complete Order';
        stickyBtn.style.backgroundColor = isAdvance ? '#25D366' : '#1e7038';
        stickyBtn.dataset.action = 'checkout';
        stickyBtn.style.width = '100%';
      }
      var stickyTextHide = document.getElementById('sticky-text-area');
      if(stickyTextHide) stickyTextHide.style.display = 'none';
    } else {
      if(stickyBtn) {
        stickyBtn.innerText = cfg.hideBundles ? 'Continue' : 'Unlock Deal';
        stickyBtn.style.backgroundColor = '#111';
        stickyBtn.dataset.action = 'scroll';
        stickyBtn.style.width = 'auto';
      }
      var stickyTextShow = document.getElementById('sticky-text-area');
      if(stickyTextShow) stickyTextShow.style.display = 'flex';
    }
  }

  function silentImageSwap(colorVal) {
    var targetVariant = null;
    for(var i = 0; i < variants.length; i++) {
        if(variants[i][cfg.colorKey] === colorVal && variants[i].featured_image) {
            targetVariant = variants[i];
            break;
        }
    }
    if (targetVariant) {
      var newSrc = targetVariant.featured_image.src;
      document.querySelectorAll('.product__media-item.is-active img, .product-media-container img, .product__media img').forEach(function(img) {
        img.src = newSrc; img.srcset = newSrc; 
      });
    }
  }

  function getMissingSizeTarget() {
    var reqCount = getRequiredItemCount();
    if (!isSplitSize && !document.querySelector('input[name="master-size"]:checked')) return 'global-size-wrapper';
    if (isSplitSize) {
      for (var i = 1; i <= reqCount; i++) {
        if (!document.querySelector('input[name="size-' + i + '"]:checked')) return 'size-' + i + '-options';
      }
    }
    return null;
  }

  function throwCheckoutError(message, targetId) {
    if (navigator.vibrate) navigator.vibrate([50, 50, 50]); 
    if (errorMsgBox) {
        errorMsgBox.textContent = message;
        errorMsgBox.style.display = 'block';
    }
    var targetEl = document.getElementById(targetId);
    if (targetEl) { targetEl.scrollIntoView({ behavior: 'smooth', block: 'center' }); triggerShake(targetId); }
  }

  function triggerShake(elementId) {
    var el = document.getElementById(elementId);
    if(el) { el.classList.remove('shake-error'); void el.offsetWidth; el.classList.add('shake-error'); }
  }

  // ⚡ EVENT DELEGATION ⚡
  bundleWrapper.addEventListener('change', function(e) {
    var target = e.target;
    var name = target.name || target.id || '';

    if (name.startsWith('master-size') || name.startsWith('size-')) {
      if (navigator.vibrate) navigator.vibrate(15); 
      localStorage.setItem('tracepk_saved_size', target.value); 

      var wrapper = document.getElementById(isSplitSize ? 'split-size-wrapper' : 'global-size-wrapper');
      wrapper.classList.remove('attention-pulse');
      
      var reqCount = getRequiredItemCount();
      var isSizeFullySelected = false;

      if (!isSplitSize) {
        isSizeFullySelected = !!document.querySelector('input[name="master-size"]:checked');
      } else {
        var sizesFound = 0;
        for(var i=1; i<=reqCount; i++) {
            if(document.querySelector('input[name="size-' + i + '"]:checked')) sizesFound++;
        }
        isSizeFullySelected = (sizesFound === reqCount);
      }

      if (isSizeFullySelected) {
        wrapper.classList.add('success-border');
        wrapper.querySelectorAll('.step1-check').forEach(function(el) { el.style.display = 'inline'; });
        
        if(!hasAutoScrolledForSize) {
           hasAutoScrolledForSize = true;
           setTimeout(function() { 
               var step2 = document.getElementById('step-2-anchor');
               if(step2 && !cfg.hideBundles) step2.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); 
               else {
                   var p1 = document.getElementById('color-picker-1');
                   if (p1) p1.scrollIntoView({ behavior: 'smooth', block: 'center' });
               }
           }, 200);
        }
      } else {
        wrapper.classList.remove('success-border');
        wrapper.querySelectorAll('.step1-check').forEach(function(el) { el.style.display = 'none'; });
      }
      
      evaluateBundleLocks();
      checkInventory(); 
      updateFunnelState();
    }

    if (name === 'master-deal') {
      if (navigator.vibrate) navigator.vibrate(15);
      var missingTarget = getMissingSizeTarget();
      if (missingTarget) {
        updateUI(false); 
        var targetEl = document.getElementById(missingTarget);
        if(targetEl) targetEl.scrollIntoView({ behavior: 'smooth', block: 'center' }); 
        triggerShake(missingTarget);
      } else { updateUI(true); }
      updateFunnelState();
    }

    if (name === 'payment-method') {
      if (navigator.vibrate) navigator.vibrate(20);
      updateFunnelState();
    }

    if (name.startsWith('color-')) {
      checkInventory();
      updateFunnelState();
    }
  });

  bundleWrapper.addEventListener('click', function(e) {
    var target = e.target.closest('input[name^="color-"]');
    if (target) {
      var missingTarget = getMissingSizeTarget();
      if (missingTarget) {
        e.preventDefault(); 
        var targetEl = document.getElementById(missingTarget);
        if(targetEl) targetEl.scrollIntoView({ behavior: 'smooth', block: 'center' }); 
        triggerShake(missingTarget);
      } else {
        if (navigator.vibrate) navigator.vibrate(15);
        silentImageSwap(target.value); 
      }
    }
  });

  if(stickyBtn) {
    stickyBtn.addEventListener('click', function(e) {
      e.preventDefault();
      if (this.dataset.action === 'checkout') {
         if (navigator.vibrate) navigator.vibrate(20);
         return processCheckout(true); 
      }
      var missingTarget = getMissingSizeTarget();
      if(missingTarget) {
         var targetEl = document.getElementById(missingTarget);
         if(targetEl) targetEl.scrollIntoView({ behavior: 'smooth', block: 'center' }); 
         triggerShake(missingTarget); 
         return; 
      }
      var p1 = document.getElementById('color-picker-1');
      if(p1) p1.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }

  function updateUI(allowColorScroll) {
    var reqCount = getRequiredItemCount();
    
    document.querySelectorAll('.package-card').forEach(function(card) {
      card.classList.remove('active-package');
    });
    var dealInput = document.querySelector('input[name="master-deal"]:checked');
    if(dealInput) {
        var activeCard = dealInput.closest('.package-card');
        if(activeCard) {
            activeCard.classList.add('active-package');
        }
    }

    if (availableColorsCount > 1) {
      for(var i=1; i<=4; i++) {
          var picker = document.getElementById('color-picker-' + i);
          if(picker) {
              if(i <= reqCount) picker.style.display = 'block';
              else picker.style.display = 'none';
          }
      }
      var colorLabel = document.getElementById('color-1-label');
      if(colorLabel) colorLabel.textContent = reqCount > 1 ? 'Item 1 Color:' : 'Choose Color:';
    }

    if(isSplitSize) {
        for(var j=1; j<=4; j++) {
            var sizeCont = document.getElementById('size-' + j + '-container');
            if(sizeCont) {
                if(j <= reqCount) sizeCont.style.display = 'block';
                else sizeCont.style.display = 'none';
            }
        }
    }

    if (allowColorScroll && reqCount > 1 && availableColorsCount > 1) {
        setTimeout(function() { 
            var p1 = document.getElementById('color-picker-1');
            if(p1) p1.scrollIntoView({ behavior: 'smooth', block: 'center' }); 
        }, 150);
    }
    
    if (reqCount > 1) { if(stickyBar) stickyBar.classList.remove('show-sticky'); } 
    else { if(stickyBar) stickyBar.classList.add('show-sticky'); }
    
    checkInventory();
  }

  function checkInventory() {
    var reqCount = getRequiredItemCount();

    for(var i=1; i<=reqCount; i++) {
        var sizeNode = isSplitSize ? document.querySelector('input[name="size-' + i + '"]:checked') : document.querySelector('input[name="master-size"]:checked');
        var sizeVal = sizeNode ? sizeNode.value : null;
        
        if(sizeVal) {
            var radios = document.querySelectorAll('input[name="color-' + i + '"]');
            radios.forEach(function(radio) {
                var colorVal = radio.value;
                var matchingVariant = null;
                for(var j=0; j < variants.length; j++) {
                    var v = variants[j];
                    if(v[cfg.sizeKey] === sizeVal && v[cfg.colorKey] === colorVal) {
                        matchingVariant = v;
                        break;
                    }
                }
                
                var soldOutBadge = radio.nextElementSibling.querySelector('.sold-out-bar');

                if (matchingVariant && matchingVariant.available) {
                    radio.disabled = false;
                    if (availableColorsCount === 1) radio.checked = true;
                    if (soldOutBadge) {
                        soldOutBadge.innerText = "SOLD OUT";
                        soldOutBadge.style.background = "rgba(170, 170, 170, 0.9)";
                    }
                }
                else { 
                    radio.disabled = true; 
                    if (radio.checked) radio.checked = false; 
                    if (soldOutBadge) {
                        soldOutBadge.innerText = "SOLD OUT";
                        soldOutBadge.style.background = "rgba(170, 170, 170, 0.9)";
                    }
                }
            });
        }
    }

    var selectedColorsMap = {};
    for (var k = 1; k <= reqCount; k++) {
        var checkedClr = document.querySelector('input[name="color-' + k + '"]:checked');
        if (checkedClr) selectedColorsMap[k] = checkedClr.value;
    }

    for (var m = 1; m <= reqCount; m++) {
        var colorRadios2 = document.querySelectorAll('input[name="color-' + m + '"]');
        colorRadios2.forEach(function(radio) {
            var cVal = radio.value;
            var chosenInOtherItem = false;
            for (var n = 1; n <= reqCount; n++) {
                if (n !== m && selectedColorsMap[n] === cVal) {
                    chosenInOtherItem = true;
                    break;
                }
            }
            var soldOutBadge = radio.nextElementSibling.querySelector('.sold-out-bar');
            
            if (chosenInOtherItem) {
                radio.disabled = true;
                if (radio.checked) {
                    radio.checked = false;
                    setTimeout(function() { updateFunnelState(); }, 10);
                }
                if(soldOutBadge) {
                    soldOutBadge.innerText = "IN USE";
                    soldOutBadge.style.background = "#dca514";
                }
            } else {
                if (!radio.disabled && soldOutBadge) {
                    soldOutBadge.style.display = ""; 
                }
            }
        });
    }
  }

  function processCheckout(isBuyNow) {
    if(errorMsgBox) errorMsgBox.style.display = 'none';
    var dealInput = document.querySelector('input[name="master-deal"]:checked');
    if(!dealInput) return;
    var deal = dealInput.value;
    var reqCount = getRequiredItemCount();
    var isAdvance = document.querySelector('input[name="payment-method"]:checked').value === 'advance';
    
    if(!isSplitSize && !document.querySelector('input[name="master-size"]:checked')) return throwCheckoutError("Please select a Size in Step 1.", 'global-size-wrapper');
    
    var selectedSizes = [];
    if(isSplitSize) {
      for(var i=1; i<=reqCount; i++) {
        var sz = document.querySelector('input[name="size-' + i + '"]:checked');
        if(!sz) return throwCheckoutError('Please select Item ' + i + ' Size.', 'size-' + i + '-options');
        selectedSizes.push(sz.value);
      }
    } else {
      var globalSizeNode = document.querySelector('input[name="master-size"]:checked');
      if(!globalSizeNode) return throwCheckoutError("Please select a Size.", 'global-size-wrapper');
      var globalSize = globalSizeNode.value;
      for(var i2=1; i2<=reqCount; i2++) selectedSizes.push(globalSize);
    }

    var selectedColors = [];
    if (cfg.colorKey) {
      for(var i3=1; i3<=reqCount; i3++) {
        var clr = document.querySelector('input[name="color-' + i3 + '"]:checked');
        if(!clr) return throwCheckoutError(reqCount > 1 ? 'Please select Item ' + i3 + ' Color.' : "Please select a Color.", 'color-picker-' + i3);
        selectedColors.push(clr.value);
      }
    }

    var selectedVariants = [];
    for(var i4=0; i4<reqCount; i4++) {
      var targetV = null;
      for(var j=0; j < variants.length; j++) {
          var v = variants[j];
          var matchSize = (v[cfg.sizeKey] === selectedSizes[i4]);
          var matchColor = !cfg.colorKey || (v[cfg.colorKey] === selectedColors[i4]);
          if (matchSize && matchColor) {
              targetV = v;
              break;
          }
      }
      if (!targetV) return throwCheckoutError("Error finding variant. Please refresh.", 'master-funnel-wrapper');
      selectedVariants.push(targetV);
    }

    var itemsMap = {};
    selectedVariants.forEach(function(v) {
       if(itemsMap[v.id]) itemsMap[v.id] += 1;
       else itemsMap[v.id] = 1;
    });
    
    var itemsPayload = Object.keys(itemsMap).map(function(id) { 
        return { id: parseInt(id, 10), quantity: itemsMap[id] };
    });

    var totalStr = document.getElementById('summary-total').innerText;
    var numericTotal = parseInt(totalStr.replace(/[^0-9]/g, ''), 10) || 0;

    // ⚡ WhatsApp In-Funnel Interception ⚡
    if (isBuyNow && isAdvance) {
      if (navigator.vibrate) navigator.vibrate(30);

      // Store payload globally for the modal submit button
      window.waCurrentPayload = {
          reqCount: reqCount,
          selectedSizes: selectedSizes,
          selectedColors: selectedColors,
          totalStr: totalStr,
          numericValue: numericTotal
      };

      // Show Modal
      var waModal = document.getElementById('whatsapp-checkout-modal');
      waModal.style.display = 'flex';
      void waModal.offsetWidth;
      waModal.style.opacity = '1';
      waModal.querySelector('.modal-content').style.transform = 'translateY(0)';

      return; 
    }

    var targetBtn = isBuyNow ? buyNowBtn : addCartBtn;
    var originalText = targetBtn.innerHTML;
    targetBtn.innerHTML = isBuyNow ? '<span class="btn-text-content" style="z-index: 2; position: relative;">🔒 Securing your deal...</span>' : '<span>Processing...</span>';
    targetBtn.style.pointerEvents = 'none';
    if(isBuyNow) { 
        targetBtn.classList.add('shimmer-btn'); 
        if (navigator.vibrate) navigator.vibrate(30); 
    }

    if (typeof fbq === 'function') fbq('track', 'AddToCart', { value: numericTotal, currency: 'PKR', content_type: 'product' });
    if (typeof ttq === 'function') ttq.track('AddToCart', { value: numericTotal, currency: 'PKR' });

    var cartDrawer = document.querySelector('cart-drawer');
    var sectionsList = [];
    if (cartDrawer) {
      sectionsList = cartDrawer.getSectionsToRender().map(function(s) { return s.id; });
    }

    var addCartPayload = {
      items: itemsPayload
    };
    if (sectionsList.length > 0) {
      addCartPayload.sections = sectionsList.join(',');
      addCartPayload.sections_url = window.location.pathname;
    }

    fetch(window.Shopify.routes.root + 'cart/add.js', {
      method: 'POST',
      headers: { 
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify(addCartPayload)
    })
    .then(function(response) {
      if (!response.ok) throw new Error('Stock issue');
      return response.json();
    })
    .then(function(responseJson) { 
      if (isBuyNow) {
        window.location.href = '/checkout'; 
      } else {
        targetBtn.style.backgroundColor = '#1e7038';
        targetBtn.style.color = '#fff';
        targetBtn.style.borderColor = '#1e7038';
        targetBtn.innerHTML = '✓ Added to Cart';
        
        if (cartDrawer) {
          cartDrawer.classList.remove('is-empty');
          if (responseJson && responseJson.sections && responseJson.sections['cart-drawer']) {
            cartDrawer.renderContents(responseJson);
            setTimeout(function() {
              targetBtn.style.backgroundColor = '';
              targetBtn.style.color = '';
              targetBtn.style.borderColor = '';
              targetBtn.innerHTML = originalText;
              targetBtn.style.pointerEvents = 'auto';
            }, 2000);
          } else {
            // Fallback: Fetch sections manually using Section Rendering API
            var sectionsToRequest = sectionsList.length > 0 ? sectionsList.join(',') : 'cart-drawer,cart-icon-bubble';
            fetch(window.location.pathname + '?sections=' + sectionsToRequest)
            .then(function(res) { return res.json(); })
            .then(function(sectionsJson) {
              var stateWithSections = Object.assign({}, responseJson, {
                sections: sectionsJson
              });
              cartDrawer.renderContents(stateWithSections);
              setTimeout(function() {
                targetBtn.style.backgroundColor = '';
                targetBtn.style.color = '';
                targetBtn.style.borderColor = '';
                targetBtn.innerHTML = originalText;
                targetBtn.style.pointerEvents = 'auto';
              }, 2000);
            })
            .catch(function(err) {
              console.error('Error fetching sections fallback:', err);
              setTimeout(function() { window.location.href = '/cart'; }, 800);
            });
          }
        } else {
          setTimeout(function() { window.location.href = '/cart'; }, 800);
        }
      }
    })
    .catch(function() {
      targetBtn.style.pointerEvents = 'auto';
      targetBtn.classList.remove('shimmer-btn');
      targetBtn.innerHTML = originalText;
      throwCheckoutError("Not enough stock available for this combination. Please try different colors!", 'color-picker-1');
    });
  }

  // ⚡ WhatsApp Form Submission Logic ⚡
  if(waSubmitBtn) {
      waSubmitBtn.addEventListener('click', function() {
          var name = document.getElementById('wa-name').value.trim();
          var phone = document.getElementById('wa-phone').value.trim();
          var address = document.getElementById('wa-address').value.trim();

          if(!name || !phone || !address) {
              alert("Please fill in all your details to proceed.");
              return;
          }

          var originalText = this.innerHTML;
          this.innerHTML = 'Connecting to WhatsApp...';
          this.style.pointerEvents = 'none';

          var p = window.waCurrentPayload;

          // ⚡ PIXEL: InitiateCheckout (Advance Pay)
          if (typeof fbq === 'function') fbq('track', 'InitiateCheckout', { value: p.numericValue, currency: 'PKR' });
          if (typeof ttq === 'function') ttq.track('InitiateCheckout', { value: p.numericValue, currency: 'PKR' });

          var msg = 'Hi ' + cfg.shopName + '! I want to place an Advance Payment order.\n\n';
          msg += '*Product:* ' + cfg.productTitle + '\n';
          msg += '*Package:* ' + (p.reqCount > 1 ? p.reqCount + '-Pack Deal' : '1 Item') + '\n';

          for(var i=0; i<p.reqCount; i++) {
              msg += (p.reqCount > 1 ? '*Item ' + (i+1) + ':* ' : '*Details:* ') + 'Size ' + p.selectedSizes[i];
              if (p.selectedColors[i]) {
                  msg += ', Color ' + p.selectedColors[i];
              }
              msg += '\n';
          }

          msg += '\n*Customer Details:*\n';
          msg += 'Name: ' + name + '\n';
          msg += 'Phone: ' + phone + '\n';
          msg += 'Address: ' + address + '\n';

          msg += '\n*Total Amount:* ' + p.totalStr + '\n\n';
          msg += 'Please share your Bank/EasyPaisa details so I can send the payment slip!';
          
          var waUrl = 'https://api.whatsapp.com/send?phone=' + cfg.whatsappNumber + '&text=' + encodeURIComponent(msg);
          window.location.href = waUrl;
          
          setTimeout(function(){
              waSubmitBtn.innerHTML = originalText;
              waSubmitBtn.style.pointerEvents = 'auto';
          }, 3000);
      });
  }

  var waCloseBtn = document.getElementById('close-wa-modal');
  var waModal = document.getElementById('whatsapp-checkout-modal');
  if(waCloseBtn && waModal) {
      waCloseBtn.addEventListener('click', function() {
          waModal.style.opacity = '0';
          waModal.querySelector('.modal-content').style.transform = 'translateY(100%)';
          setTimeout(function() { waModal.style.display = 'none'; }, 300);
      });
      waModal.addEventListener('click', function(e) {
          if(e.target === waModal) waCloseBtn.click();
      });
  }

  var toggleSizeBtn = document.getElementById('toggle-size-btn');
  if(toggleSizeBtn) {
    toggleSizeBtn.addEventListener('click', function(e) {
      e.preventDefault(); if (navigator.vibrate) navigator.vibrate(10);
      isSplitSize = !isSplitSize;
      if(isSplitSize) {
        document.getElementById('global-size-wrapper').style.display = 'none';
        document.getElementById('split-size-wrapper').style.display = 'block';
        this.innerText = '↹ Use same size for all items';
      } else {
        document.getElementById('global-size-wrapper').style.display = 'block';
        document.getElementById('split-size-wrapper').style.display = 'none';
        this.innerText = '↹ Need different sizes for each item?';
      }
      evaluateBundleLocks();
      updateUI(false);
      updateFunnelState();
    });
  }

  function updateDeliveryEstimate() {
    var d = new Date();
    var utc = d.getTime() + (d.getTimezoneOffset() * 60000);
    var pktNow = new Date(utc + (3600000 * 5)); 
    
    var cutoffHour = 14; 
    var isPastCutoff = pktNow.getHours() >= cutoffHour;
    
    var minDays = 3, maxDays = 5;
    if (isPastCutoff) { minDays++; maxDays++; }
    
    var minDate = new Date(pktNow); minDate.setDate(pktNow.getDate() + minDays);
    var maxDate = new Date(pktNow); maxDate.setDate(pktNow.getDate() + maxDays);
    var options = { weekday: 'short', month: 'short', day: 'numeric' };
    
    var cutoffDate = new Date(pktNow);
    if (isPastCutoff) cutoffDate.setDate(pktNow.getDate() + 1);
    cutoffDate.setHours(cutoffHour, 0, 0, 0);
    
    var diff = cutoffDate - pktNow;
    var hoursLeft = Math.floor((diff % 86400000) / 3600000);
    var minsLeft = Math.floor((diff % 3600000) / 60000);
    
    var deliveryEl = document.getElementById('delivery-text');
    if (deliveryEl) deliveryEl.innerHTML = 'Order within <strong style="color:#111;">' + hoursLeft + 'h ' + minsLeft + 'm</strong> to get it by <strong style="color:#111;">' + minDate.toLocaleDateString('en-US', options) + ' - ' + maxDate.toLocaleDateString('en-US', options) + '</strong>';
  }

  if(addCartBtn) addCartBtn.addEventListener('click', function() { processCheckout(false); });
  if(buyNowBtn) buyNowBtn.addEventListener('click', function() { processCheckout(true); });

  evaluateBundleLocks();
  updateUI(false); 
  updateFunnelState();
  updateDeliveryEstimate();
  setInterval(updateDeliveryEstimate, 60000); 

  var descBtn = document.getElementById('desc-accordion-btn');
  var descContent = document.getElementById('desc-accordion-content');
  var descIcon = document.getElementById('desc-accordion-icon');
  if (descBtn && descContent) {
    descBtn.addEventListener('click', function(e) {
      e.preventDefault();
      if (navigator.vibrate) navigator.vibrate(10);
      if (descContent.style.maxHeight && descContent.style.maxHeight !== '0px') {
        descContent.style.maxHeight = '0px';
        descIcon.style.transform = 'rotate(0deg)';
      } else {
        descContent.style.maxHeight = (descContent.scrollHeight + 2000) + 'px';
        descIcon.style.transform = 'rotate(45deg)';
      }
    });
  }

  // ⚡ SIZE GUIDE MODAL LOGIC ⚡
  var modal = document.getElementById('size-guide-modal');
  ['open-size-guide', 'open-size-guide-split', 'open-size-guide-bottom'].forEach(function(id) {
    var btn = document.getElementById(id);
    if(btn) {
        btn.addEventListener('click', function(e) { 
            e.preventDefault(); 
            if(navigator.vibrate) navigator.vibrate(10); 
            if(modal) { 
                modal.style.display = 'flex'; 
                void modal.offsetWidth; 
                modal.style.opacity = '1'; 
                var mc = modal.querySelector('.modal-content');
                if(mc) mc.style.transform = 'translateY(0)'; 
            } 
        });
    }
  });
  
  var closeBtn = document.getElementById('close-size-guide');
  if(closeBtn) {
      closeBtn.addEventListener('click', function() { 
          if(modal) { 
              modal.style.opacity = '0'; 
              var mc = modal.querySelector('.modal-content');
              if(mc) mc.style.transform = 'translateY(20px)'; 
              setTimeout(function() { modal.style.display = 'none'; }, 300); 
          } 
      });
  }
  
  if(modal) {
      modal.addEventListener('click', function(e) { 
          if(e.target === modal && closeBtn) closeBtn.click(); 
      });
  }
});
</script>