{% comment %}
  TRACEPK ALL-IN-ONE SWATCH LOGIC (VERSION 4.0 - JAVASCRIPT CRASH FIX)
{% endcomment %}

<div class="tracepk-swatches-container">
  <style>
    :root {
      --trace-soldout-bg: rgba(160, 160, 160, 0.75); 
      --trace-soldout-text: #ffffff;
      --trace-active-border: 2px solid #000000; 
      --trace-product-grid-mobile: repeat(3, 1fr);
      --trace-product-grid-desktop: repeat(4, 1fr);
    }

    /* Force hide input but keep it in DOM for JS */
    .tracepk-swatches-container input.trace-hidden-radio {
      position: absolute !important;
      opacity: 0 !important;
      width: 0 !important;
      height: 0 !important;
    }
    
    .tracepk-swatches-container .trace-color-grid {
      display: grid !important;
      grid-template-columns: var(--trace-product-grid-mobile) !important;
      gap: 12px !important;
      margin-top: 15px !important;
      width: 100% !important;
      border: none !important;
      padding: 0 !important;
    }
    
    @media (min-width: 750px) {
      .tracepk-swatches-container .trace-color-grid {
        grid-template-columns: var(--trace-product-grid-desktop) !important;
      }
    }

    .tracepk-swatches-container label.trace-card-label {
      display: flex !important;
      flex-direction: column !important;
      cursor: pointer !important;
      border: 1px solid #e3e3e3 !important;
      border-radius: 6px !important;
      overflow: hidden !important;
      height: 100% !important;
      background: #ffffff !important;
      transition: all 0.2s ease !important;
      padding: 0 !important;
      margin: 0 !important;
    }

    .tracepk-swatches-container input.trace-hidden-radio:checked + label.trace-card-label {
      border: var(--trace-active-border) !important;
      box-shadow: 0 0 0 1px #000000 !important; 
    }

    .tracepk-swatches-container .trace-card-image-wrap {
      position: relative !important;
      width: 100% !important;
      aspect-ratio: 3 / 4 !important;
      background-color: #f4f4f4 !important;
      overflow: hidden !important;
    }

    .tracepk-swatches-container .trace-card-image-wrap img {
      position: absolute !important;
      top: 0 !important;
      left: 0 !important;
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
      transition: opacity 0.2s ease !important;
    }

    /* --- THE DYNAMIC JS SYNC --- */
    
    /* 1. Hide the badge by default */
    .tracepk-swatches-container .trace-sold-out-badge {
      position: absolute !important;
      bottom: 0 !important;
      width: 100% !important;
      background: var(--trace-soldout-bg) !important;
      color: var(--trace-soldout-text) !important;
      text-align: center !important;
      padding: 6px 0 !important;
      font-size: 11px !important;
      font-weight: 700 !important;
      z-index: 2 !important;
      display: none !important; 
    }

    /* 2. Show badge & dim image ONLY when JS adds 'disabled' class to the input */
    .tracepk-swatches-container input.trace-hidden-radio.disabled + label .trace-card-image-wrap img,
    .tracepk-swatches-container input.trace-hidden-radio:disabled + label .trace-card-image-wrap img {
      opacity: 0.5 !important;
    }
    
    .tracepk-swatches-container input.trace-hidden-radio.disabled + label .trace-sold-out-badge,
    .tracepk-swatches-container input.trace-hidden-radio:disabled + label .trace-sold-out-badge {
      display: block !important;
    }
    /* ---------------------------- */

    .tracepk-swatches-container .trace-card-info {
      padding: 10px 8px !important;
      text-align: left !important;
      display: flex !important;
      flex-direction: column !important;
      background: #ffffff !important;
    }

    .tracepk-swatches-container .trace-color-name {
      display: block !important;
      font-size: 13px !important;
      font-weight: 600 !important;
      color: #121212 !important;
      margin-bottom: 4px !important;
    }

    .tracepk-swatches-container .trace-color-price {
      display: block !important;
      font-size: 12px !important;
      color: #777777 !important;
    }
  </style>

  <div class="trace-color-grid">
    {%- for value in option.values -%}
      
      {%- liquid
        assign matching_variant = blank
        
        for variant in product.variants
          if variant.options contains value
            assign matching_variant = variant
            break
          endif
        endfor

        assign option_disabled = true
        if value.available
          assign option_disabled = false
        endif
      -%}

      <div class="trace-color-card">
        <input 
          type="radio" 
          id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
          name="{{ option.name }}-{{ option.position }}"
          value="{{ value | escape }}"
          form="{{ product_form_id }}"
          {% if value.selected %}checked{% endif %}
          class="trace-hidden-radio {% if option_disabled %}disabled{% endif %}"
          data-product-url="{{ value.product_url }}"
          data-option-value-id="{{ value.id }}"
        >
        
        <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}" class="trace-card-label">
          
          {%- comment -%} CRITICAL FIX: Dawn needs this hidden span or the JS crashes {%- endcomment -%}
          <span class="visually-hidden label-unavailable">
            {{- 'products.product.variant_sold_out_or_unavailable' | t -}}
          </span>

          <div class="trace-card-image-wrap">
            {%- if matching_variant.featured_image -%}
              <img src="{{ matching_variant.featured_image | image_url: width: 400 }}" alt="{{ value | escape }}" loading="lazy">
            {%- else -%}
              <div class="trace-placeholder" style="width:100%; height:100%; background:#eee;"></div>
            {%- endif -%}
            
            <div class="trace-sold-out-badge">SOLD OUT</div>
          </div>
          
          <div class="trace-card-info">
            <span class="trace-color-name">{{ value }}</span>
            <span class="trace-color-price">{{ matching_variant.price | money }}</span>
          </div>
        </label>
      </div>
    {%- endfor -%}
  </div>
</div>